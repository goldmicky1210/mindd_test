# OpenAI API Key (required for LLM reasoning; embeddings fall back to sentence-transformers if not set)
OPENAI_API_KEY=sk-...

# Embedding model: "openai" or "sentence-transformers"
EMBEDDING_MODEL=sentence-transformers

# Sentence-Transformers model name (used when EMBEDDING_MODEL=sentence-transformers)
ST_MODEL_NAME=all-MiniLM-L6-v2

# OpenAI model for chat completion
OPENAI_CHAT_MODEL=gpt-4o-mini

# Top-K chunks to retrieve per query
RETRIEVAL_TOP_K=5

# Storage paths
STORAGE_DIR=storage
DATA_DIR=data/startups

# SQLite database path
DB_URL=sqlite:///storage/mindd.db
